# drill-api configuration — copy to .env (mode 640) on the VPS. Never commit .env.
PORT=4252
HOST=127.0.0.1
DB_PATH=/opt/drill-api/data/drill.db

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
#   Authorized redirect URI: https://drill.celox.io/api/auth/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=https://drill.celox.io/api/auth/callback

APP_ORIGIN=https://drill.celox.io
SESSION_SECRET=replace-with-openssl-rand-hex-32
ADMIN_EMAILS=martinpaush@gmail.com

# SMTP (Hostinger) — leave USER/PASS empty to disable all email features.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@celox.io
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=drill <support@celox.io>
SMTP_BCC=martin.pfeffer@celox.io

# Timezone for streak boundaries + cron schedules
TZ_NAME=Europe/Berlin
